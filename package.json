{
  "name": "roundhouse",
  "version": "0.1.0",
  "description": "A desktop catalog for model train collections.",
  "main": "./out/main/index.js",
  "author": "Steve Beamesderfer",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
