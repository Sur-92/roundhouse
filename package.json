{
  "name": "roundhouse",
  "version": "0.5.3",
  "description": "A desktop catalog for model train and coin collections.",
  "main": "./out/main/index.js",
  "author": "Steve Beamesderfer",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite build && electron .",
    "build:win": "electron-vite build && electron-builder --win",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "rebuild": "electron-builder install-app-deps",
    "setup": "npm install --ignore-scripts && node node_modules/electron/install.js && electron-builder install-app-deps"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "better-sqlite3": "^11.7.0",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
